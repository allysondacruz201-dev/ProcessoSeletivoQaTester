    {
      "name": "Update Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 403\", function () {\r",
              "    pm.response.to.have.status(403);\r",
              "});\r",
              "\r",
              "pm.test(\"Access denied with invalid token\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Forbidden\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "PUT",
        "header": [
          {
            "key": "cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"No\",\r\n    \"lastname\": \"Auth\",\r\n    \"totalprice\": 1300,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-06-12\",\r\n        \"checkout\": \"2026-06-20\"\r\n    },\r\n    \"additionalneeds\": \"Lunch\"\r\n}",
